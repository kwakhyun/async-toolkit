{
  "name": "async-toolkit",
  "version": "0.2.0",
  "description": "Zero-dependency async toolkit for TypeScript — retry, timeout, pLimit, pMap, sleep, defer & error-as-value. Tree-shakeable, ESM + CJS.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "async",
    "await",
    "promise",
    "retry",
    "backoff",
    "timeout",
    "concurrency",
    "p-limit",
    "p-map",
    "sleep",
    "delay",
    "defer",
    "deferred",
    "toolkit",
    "esm",
    "cjs",
    "typescript"
  ],
  "author": "kwakhyun <khyun9685@gmail.com>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/kwakhyun/async-toolkit.git"
  },
  "bugs": {
    "url": "https://github.com/kwakhyun/async-toolkit/issues"
  },
  "homepage": "https://github.com/kwakhyun/async-toolkit#readme",
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
